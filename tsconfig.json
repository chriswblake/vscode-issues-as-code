{
  "compilerOptions": {
    "module": "node16",
    "target": "ES2020",
    "outDir": "out",
    "lib": ["ES2020"],
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "node16",
    "esModuleInterop": true
  },
  "include": ["src", "test"],
  "exclude": ["node_modules", ".vscode-test"]
}
