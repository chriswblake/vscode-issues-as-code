{
  "issuesAsCode.syncTargets": [
    {
      "filesDir": ".issues/playground/open",
      "naming": "{gh-issues.number}-{gh-issues.title}",
      "gh-issues": {
        "limit": 100,
        "filters": {
          "repository": "chriswblake/playground",
          "state": "open",
          "assignee:": "chriswblake",
          "author:": "chriswblake",
          "label": ["bug", "help wanted"],
          "created_at": ">2025-01-01"
        }
      }
    },
    {
      "filesDir": ".issues/issues-as-code/open",
      "naming": "{gh-issues}-{gh-issues.title}",
      "gh-issues": {
        "filters": {
          "repository": "chriswblake/vscode-issues-as-code-testing",
          "state": "open"
        }
      }
    },
    {
      "filesDir": ".issues/team-projects/open",
      "naming": "{number}-{title}",
      "gh-projects": {
        "filters": {
          "projectId": "12345",
          "state": "open",
          "field1": "value1",
          "field2": "value2"
        }
      }
    },
    {
      "filesDir": ".issues/GPM Inbox",
      "naming": "{tick-tick.id}-{tick-tick.title}",
      "tick-tick": {
        "filters": {
          "list": "GPM Inbox",
          "state": "open"
        }
      },
      "gh-issues": {
        "filters": {
          "repository": "chriswblake/gpm-inbox",
          "state": "open"
        }
      }
    }
  ]
}
